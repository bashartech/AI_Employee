# AI Employee Vault - Git Ignore File

# ==================== SENSITIVE DATA ====================
# Environment variables and credentials
.env
.env.local
.env.*.local
credentials.json
gmail_token.json
token.json
*.key
*.pem
*.p12

# ==================== TASK FOLDERS (User Data) ====================
# These contain sensitive user emails, messages, and tasks
Needs Action/
Pending Approval/
Approved/
Done/
Rejected/
Inbox/
Send_Queue/
Odoo_Data/

# Keep folder structure but ignore contents
!Needs Action/.gitkeep
!Pending Approval/.gitkeep
!Approved/.gitkeep
!Done/.gitkeep
!Rejected/.gitkeep
!Inbox/.gitkeep
!Send_Queue/.gitkeep
!Odoo_Data/.gitkeep

# ==================== PYTHON ====================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
virtualenv/

# Unit test / coverage
.coverage
.pytest_cache/
htmlcov/

# ==================== NODE.JS ====================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ==================== LOGS ====================
*.log
logs/
audit_log.json
activity_log.json

# ==================== TEMPORARY FILES ====================
temp/
tmp/
*.tmp
*.temp
*.bak
*.swp
*~
.email_temp.json

# ==================== IDE / EDITORS ====================
# VSCode
.vscode/
*.code-workspace
token.pickle
# PyCharm / IntelliJ
.idea/
*.iml
linkedin_session
# Sublime Text
*.sublime-project
*.sublime-workspace
