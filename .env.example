# Environment Configuration for AI Employee Vault

# Qwen Configuration (for automation)
# Option 1: Local Ollama (FREE - recommended)
QWEN_BASE_URL=http://localhost:11434/v1
QWEN_API_KEY=dummy-key
QWEN_MODEL=qwen2.5:latest

# Option 2: Qwen Cloud API
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_API_KEY=your-qwen-api-key-here
# QWEN_MODEL=qwen-plus

# AI API Keys (optional - for other integrations)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Gmail API Configuration
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# WhatsApp Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# LinkedIn Configuration
LINKEDIN_USERNAME=your_linkedin_email
LINKEDIN_PASSWORD=your_linkedin_password

# Engine Configuration
LOG_LEVEL=INFO
POLL_INTERVAL=60
MAX_REASONING_ITERATIONS=5

# Approval Settings
REQUIRE_APPROVAL_FOR_FINANCIAL=true
REQUIRE_APPROVAL_FOR_SENSITIVE=true
